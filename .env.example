# ─────────────────────────────────────────────────────────
# Fin Approvals Enterprise v3 — Environment Template
# Copy to server/.env — NEVER commit to version control
# ─────────────────────────────────────────────────────────

# Database
DATABASE_URL=postgres://postgres:postgres@db:5432/lejimet

# JWT — generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_64_RANDOM_HEX_CHARS

# CORS — comma-separated allowed origins
ALLOWED_ORIGINS=http://localhost:18080

# App public URL (used in email links and PWA)
APP_URL=http://localhost:18080

# SMTP
SMTP_HOST=mail.yourdomain.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=noreply@yourdomain.com
SMTP_PASS=CHANGE_ME
MAIL_FROM=Fin Approvals <noreply@yourdomain.com>

# Final approval notification
LEJIMET_EMAIL=finance@yourdomain.com

# Server port
PORT=8080
